---
import "../styles/global.css";
---

<html lang="en">
  <head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width" />
    <title>Golden Static Template</title>
    <meta
      name="description"
      content="Astro static site template with strict quality gates."
    />
  </head>
  <body>
    <main class="mx-auto max-w-3xl px-6 py-16">
      <p class="text-sm tracking-wider text-zinc-500 uppercase">
        Spencer Smith
      </p>
      <h1 class="mt-4 text-4xl font-semibold tracking-tight">
        Golden Static Template
      </h1>
      <p class="mt-4 text-lg text-zinc-700">
        Start here for content-first Astro projects with strict TypeScript,
        lint, format, and test gates.
      </p>
    </main>
  </body>
</html>
